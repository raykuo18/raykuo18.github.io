@article{kuo2026vlm,
  title        = {Do {VLMs} Need Vision Transformers? {Evaluating} State Space Models as Vision Encoders},
  author       = {Kuo, Shang-Jui and Cascante-Bonilla, Paola},
  year         = {2026},
  note         = {Under review},
  arxiv        = {2603.19209},
  website      = {https://lab-spell.github.io/vlm-ssm-vision-encoders/},
  code         = {https://github.com/raykuo18/vlm-ssm-vision-encoders},
  selected     = {true},
  preview      = {vlm_thumb.png},
  abstract     = {We conduct a controlled study comparing Transformer, SSM,
                  and hybrid vision backbones as frozen encoders in a
                  LLaVA-style VLM pipeline. Under matched pretraining
                  conditions, SSM backbones (VMamba) provide substantially
                  stronger spatial grounding while remaining competitive on
                  open-ended VQA, and can match or outperform much larger
                  ViT-based encoders on localization benchmarks. We further
                  show that localization failures can be stabilized with
                  simple interface adjustments.},
  additional_info = {. Featured on Hugging Face Daily Papers},
}

@inproceedings{kuo2024footulcer,
  title        = {Improving Limited Supervised Foot Ulcer Segmentation Using Cross-Domain Augmentation},
  author       = {Kuo, Shang-Jui and Huang, Po-Han and Lin, Chia-Ching
                  and Li, Jeng-Lin and Chang, Ming-Ching},
  booktitle    = {IEEE International Conference on Acoustics, Speech and
                  Signal Processing (ICASSP)},
  year         = {2024},
  arxiv        = {2401.08422},
  website      = {https://ai.inventec.com/en/ai/improving-limited-supervised-foot-ulcer-segmentation-using-cross-domain-augmentation/},
  selected     = {true},
  preview      = {icassp_thumb.png},
  abstract     = {We propose a cross-domain augmentation methodology to
                  improve wound segmentation under limited supervision,
                  achieving a 34% Dice score improvement in real hospital
                  deployment.},
  additional_info = {. &#42; Equal contribution (Kuo and Huang)},
}
